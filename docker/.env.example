############
# Secrets
# YOU MUST CHANGE THESE BEFORE GOING INTO PRODUCTION
############

# PostgreSQL password for the `postgres` user
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password

# JWT secret used to sign and verify tokens (min 32 chars)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# JWT expiry in seconds (default: 3600 = 1 hour)
JWT_EXPIRY=3600

############
# API Keys
# Generate these using the JWT secret above
# Use https://supabase.com/docs/guides/self-hosting#api-keys
############

# Anon key (public, used in browser)
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (private, server-side only)
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

############
# URLs
############

# External API URL (Supabase API accessible from outside)
API_EXTERNAL_URL=https://supabase.oguzhansert.dev

# Site URL (your Next.js app)
SITE_URL=https://oguzhansert.dev

# Additional redirect URLs for auth (comma-separated)
ADDITIONAL_REDIRECT_URLS=https://oguzhansert.dev/**,http://localhost:3001/**

############
# Auth Config
############

# Set to true to disable new user signups
DISABLE_SIGNUP=false

# Set to true to auto-confirm email signups (no verification email)
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

############
# PostgREST
############

# Schemas exposed via the API
PGRST_DB_SCHEMAS=public,storage,graphql_public
